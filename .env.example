# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@postgres:5432/marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_STRONG_DB_PASSWORD
POSTGRES_DB=marketplace

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Payment service
PAYMENT_SERVICE_URL=http://payment:8001
PAYMENT_DB_DSN=postgres://postgres:YOUR_PASSWORD@postgres:5432/marketplace?sslmode=disable

# Demo features: set to false in production
DEMO_MODE=false
