# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=marketplace

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Payment service
PAYMENT_SERVICE_URL=http://payment:8001

# Go payment service DB (same postgres, schema payments)
PAYMENT_DB_DSN=postgres://postgres:postgres@postgres:5432/marketplace?sslmode=disable
